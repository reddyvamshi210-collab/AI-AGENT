# ============================================
# CareerForge Agent - Environment Variables
# ============================================
# Copy this file to .env and fill in your keys

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Google OAuth 2.0 (Gmail + Calendar)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Backend
BACKEND_URL=http://localhost:8000
BACKEND_SECRET_KEY=your_secret_key_change_in_production
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# Frontend URL (used by backend to redirect after Google OAuth)
# In production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# ChromaDB (Resume RAG)
CHROMA_PERSIST_DIR=./backend/data/chroma_db

# ─── PRODUCTION VALUES (Vercel + Render) ────────────────────────────────────
# NEXT_PUBLIC_API_URL=https://your-app.onrender.com
# FRONTEND_URL=https://your-app.vercel.app
# BACKEND_CORS_ORIGINS=["https://your-app.vercel.app"]
# GOOGLE_REDIRECT_URI=https://your-app.onrender.com/auth/google/callback
